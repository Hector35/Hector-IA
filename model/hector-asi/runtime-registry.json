{
  "schemaVersion": "1.1.0",
  "project": "Hector ASI",
  "operationalBase": {
    "id": "hector-base",
    "name": "Héctor Base",
    "status": "active",
    "deployment": "cloudflare-workers-ai",
    "customWeights": false,
    "identityAndOrchestrationOwnedByHector": true,
    "models": {
      "conversation": "@cf/meta/llama-3.2-3b-instruct",
      "utility": "@cf/ibm-granite/granite-4.0-h-micro",
      "deterministic": "hector-rules-v1"
    },
    "routing": {
      "interactiveChat": "hector-base-only",
      "ordinaryConversation": "single open-model response",
      "advancedConversation": "open-model architect, adversary and judge passes",
      "currentInformation": "no live web in chat; disclose the limit or request evidence",
      "sensitiveRequests": "conservative open-model response with explicit limits",
      "failurePolicy": "fail closed; never fallback to OpenAI"
    },
    "evidence": [
      "worker/lib/free-first.ts",
      "worker/lib/providers.ts",
      "worker/lib/planned-response.ts",
      "worker/lib/execution-plan.ts",
      "response_traces.provider",
      "response_traces.model"
    ]
  },
  "openAI": {
    "interactiveChatAllowed": false,
    "role": "training-and-evaluation-only",
    "allowedUses": [
      "licensed dataset generation",
      "teacher critique and preference generation",
      "candidate evaluation",
      "training pipeline diagnostics"
    ],
    "forbiddenUses": [
      "answering interactive chat",
      "fallback after an open-model error",
      "silent escalation for complex, sensitive or current requests"
    ]
  },
  "customCandidate": {
    "registry": "model/hector-asi/model-registry.json",
    "id": "hector-asi-v0.1-qwen3-4b-sft",
    "status": "planned",
    "customWeightsAvailable": false
  },
  "champion": null
}
