{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hector-os",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-19",
  "observability": { "enabled": true },
  "triggers": { "crons": ["* * * * *"] },
  "vars": {
    "OPENAI_MODEL": "gpt-5.6-terra",
    "OPENAI_MODEL_FAST": "gpt-5.6-luna",
    "OPENAI_MODEL_BALANCED": "gpt-5.6-terra",
    "OPENAI_MODEL_REASONING": "gpt-5.6-sol",
    "CLOUDFLARE_MODEL_FAST": "@cf/meta/llama-3.1-8b-instruct-fast",
    "CLOUDFLARE_AI_ENABLED": "true",
    "HECTOR_FREE_FIRST_ENABLED": "true",
    "HECTOR_CACHE_TTL_SECONDS": "86400",
    "APP_NAME": "Héctor OS"
  },
  "ai": { "binding": "AI" },
  "d1_databases": [{ "binding": "DB", "database_name": "hector-os-db", "database_id": "16303e77-d2e8-463d-b6a4-77a9c77df0ee", "migrations_dir": "migrations" }],
  "r2_buckets": [{ "binding": "FILES", "bucket_name": "hector-os-files" }]
}
