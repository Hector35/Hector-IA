{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hector-os",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-19",
  "observability": { "enabled": true },
  "triggers": { "crons": ["* * * * *"] },
  "vars": {
    "OPENAI_MODEL": "gpt-5.6-terra",
    "OPENAI_MODEL_FAST": "gpt-5.6-luna",
    "OPENAI_MODEL_BALANCED": "gpt-5.6-terra",
    "OPENAI_MODEL_REASONING": "gpt-5.6-sol",
    "CLOUDFLARE_MODEL_FAST": "@cf/qwen/qwen3-30b-a3b-fp8",
    "CLOUDFLARE_MODEL_UTILITY": "@cf/ibm-granite/granite-4.0-h-micro",
    "CLOUDFLARE_AI_ENABLED": "true",
    "HECTOR_FREE_FIRST_TIMEOUT_MS": "20000",
    "HECTOR_QWEN_ENABLED": "true",
    "HECTOR_QWEN_MODEL": "Qwen/Qwen3-4B-Instruct-2507",
    "HECTOR_QWEN_BASE_URL": "https://router.huggingface.co/v1",
    "HECTOR_QWEN_TIMEOUT_MS": "30000",
    "HECTOR_CUSTOM_MODEL_ENABLED": "false",
    "HECTOR_CUSTOM_MODEL_ID": "hector-asi-qwen15-v10",
    "HECTOR_CUSTOM_MODEL_LABEL": "Héctor Qwen15 v10",
    "HECTOR_CUSTOM_MODEL_TIMEOUT_MS": "60000",
    "APP_NAME": "Héctor OS"
  },
  "ai": { "binding": "AI" },
  "d1_databases": [{ "binding": "DB", "database_name": "hector-os-db", "database_id": "16303e77-d2e8-463d-b6a4-77a9c77df0ee", "migrations_dir": "migrations" }],
  "r2_buckets": [{ "binding": "FILES", "bucket_name": "hector-os-files" }]
}
